---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allEpisodes = await getCollection('episodes');
const episodes = allEpisodes.sort((a, b) => a.data.order - b.data.order);

const currentPath = Astro.url.pathname;
const currentEp = episodes.find(ep => currentPath.includes(`/ep${String(ep.data.order).padStart(2,'0')}`));
const currentIdx = currentEp ? episodes.indexOf(currentEp) : -1;
const prevEp = currentIdx > 0 ? episodes[currentIdx - 1] : null;
const nextEp = currentIdx < episodes.length - 1 ? episodes[currentIdx + 1] : null;
---

<BaseLayout title={currentEp ? `第${currentEp.data.order}集：${currentEp.data.title} — 魏晉南北朝史` : '魏晉南北朝史'}>
  <div class="episode-layout">
    {currentEp && (
      <>
        <nav class="episode-nav">
          <a href="/wei-jin-history-learning/episodes" class="back">
            <span>←</span> 返回課程列表
          </a>
          <div class="nav-arrows">
            {prevEp ? (
              <a href={`/wei-jin-history-learning/episodes/ep${String(prevEp.data.order).padStart(2,'0')}`} class="nav-btn">
                ← 第{prevEp.data.order}集
              </a>
            ) : <span />}
            <span class="ep-counter">第{currentEp.data.order}集 / 共15集</span>
            {nextEp ? (
              <a href={`/wei-jin-history-learning/episodes/ep${String(nextEp.data.order).padStart(2,'0')}`} class="nav-btn">
                第{nextEp.data.order}集 →
              </a>
            ) : <span />}
          </div>
        </nav>

        <article class="episode-content">
          <header class="episode-header">
            <div class="ep-badge">第{currentEp.data.order}集</div>
            <h1>{currentEp.data.title}</h1>
            <p class="subtitle">{currentEp.data.subtitle}</p>
            <div class="tags">
              {currentEp.data.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </header>
          <div class="prose">
            <slot />
          </div>
        </article>
      </>
    )}
  </div>
</BaseLayout>

<style>
  .episode-layout { max-width: 780px; margin: 0 auto; padding: 0 24px 80px; }

  .episode-nav {
    display: flex; align-items: center; justify-content: space-between;
    padding: 28px 0 32px;
    gap: 16px; flex-wrap: wrap;
  }
  .back {
    color: var(--text-muted); text-decoration: none;
    font-size: 14px; display: flex; align-items: center; gap: 6px;
    transition: color 0.2s;
  }
  .back:hover { color: var(--text); }
  .nav-arrows { display: flex; align-items: center; gap: 12px; }
  .nav-btn {
    color: var(--text-muted); text-decoration: none;
    font-size: 14px; padding: 6px 12px;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 8px; transition: all 0.2s;
  }
  .nav-btn:hover { color: var(--text); border-color: var(--accent-dim); }
  .ep-counter { color: var(--text-dim); font-size: 13px; }

  .episode-header {
    padding-bottom: 32px; margin-bottom: 40px;
    border-bottom: 1px solid var(--border);
  }
  .ep-badge {
    display: inline-block;
    background: rgba(229,168,75,0.12);
    color: var(--accent); font-size: 12px; font-weight: 700;
    padding: 4px 12px; border-radius: 6px; margin-bottom: 16px;
    letter-spacing: 0.5px;
  }
  h1 {
    font-family: 'Noto Serif TC', serif;
    font-size: clamp(22px, 5vw, 32px); font-weight: 700;
    line-height: 1.3; margin-bottom: 12px;
  }
  .subtitle { color: var(--text-muted); font-size: 15px; margin-bottom: 16px; }
  .tags { display: flex; gap: 8px; flex-wrap: wrap; }
  .tag {
    background: var(--bg-card); border: 1px solid var(--border);
    color: var(--text-dim); font-size: 12px;
    padding: 3px 10px; border-radius: 6px;
  }

  /* Prose styles for markdown content */
  .prose :global(h2) {
    font-family: 'Noto Serif TC', serif;
    font-size: 20px; font-weight: 700;
    color: var(--accent); margin: 40px 0 20px;
    padding-bottom: 10px; border-bottom: 1px solid var(--border);
  }
  .prose :global(h3) {
    font-family: 'Noto Serif TC', serif;
    font-size: 17px; font-weight: 700;
    margin: 28px 0 14px;
  }
  .prose :global(p) {
    font-size: 16px; line-height: 1.9; color: var(--text-muted);
    margin-bottom: 16px;
  }
  .prose :global(strong) { color: var(--text); font-weight: 600; }
  .prose :global(em) { color: var(--text); font-style: italic; }
  .prose :global(hr) {
    border: none; border-top: 1px solid var(--border);
    margin: 36px 0;
  }

  /* Special box styles */
  .prose :global(.story-box) {
    background: linear-gradient(135deg, rgba(229,168,75,0.08), rgba(229,168,75,0.03));
    border-left: 3px solid var(--accent);
    border-radius: 0 12px 12px 0;
    padding: 18px 22px; margin: 20px 0;
  }
  .prose :global(.think-box) {
    background: rgba(74,222,128,0.06);
    border: 1px solid rgba(74,222,128,0.15);
    border-radius: 12px; padding: 18px 22px; margin: 20px 0;
  }
  .prose :global(.modern-box) {
    background: rgba(96,165,250,0.06);
    border: 1px solid rgba(96,165,250,0.15);
    border-radius: 12px; padding: 18px 22px; margin: 20px 0;
  }
  .prose :global(.summary-box) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px; padding: 24px; margin: 32px 0;
  }
  .prose :global(.think-box h4),
  .prose :global(.modern-box h4),
  .prose :global(.summary-box h3) {
    font-size: 14px; margin-bottom: 10px;
  }
  .prose :global(.think-box h4) { color: var(--green); }
  .prose :global(.modern-box h4) { color: var(--blue); }
  .prose :global(.summary-box h3) { color: var(--accent); }
  .prose :global(.think-box p),
  .prose :global(.modern-box p) { font-size: 15px; margin-bottom: 0; }
  .prose :global(.summary-box ul) {
    list-style: none; display: grid; gap: 8px;
  }
  .prose :global(.summary-box li) {
    font-size: 14px; color: var(--text-muted);
    padding: 10px 14px; background: var(--bg);
    border-radius: 8px;
  }
  .prose :global(.summary-box li::before) {
    content: '✦'; color: var(--accent); margin-right: 8px;
  }
  .prose :global(.core-questions) {
    margin-top: 48px; padding-top: 32px;
    border-top: 1px solid var(--border);
  }
  .prose :global(.core-questions h2) {
    font-family: 'Noto Serif TC', serif;
    font-size: 18px; color: var(--purple);
    margin-bottom: 20px; border: none; padding: 0;
  }
  .prose :global(.question-item) {
    background: rgba(167,139,250,0.06);
    border: 1px solid rgba(167,139,250,0.15);
    border-radius: 12px; padding: 18px 22px; margin-bottom: 14px;
  }
  .prose :global(.question-item h4) {
    color: var(--purple); font-size: 14px; margin-bottom: 8px;
  }
  .prose :global(.question-item p) { font-size: 14px; margin-bottom: 0; }
</style>
