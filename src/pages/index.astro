---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allEpisodes = await getCollection('episodes');
const episodes = allEpisodes.sort((a, b) => a.data.order - b.data.order);
const extractCoreQuestions = (body) => {
  const match = body.match(/##\s*(?:【)?核心問題(?:】)?[^\n]*\n([\s\S]*)$/);
  if (!match) return [];

  return match[1]
    .split('\n')
    .map(line => line.trim())
    .filter(line => /^\d+\./.test(line))
    .map(line => line.replace(/^\d+\.\s*/, '').trim());
};

const featuredEpisodes = episodes.slice(0, 6).map((ep) => ({
  ...ep,
  coreQuestions: extractCoreQuestions(ep.body),
}));
---

<BaseLayout title="魏晉南北朝史 — 甘懷真教授 | 國中歷史學習網" description="臺灣大學甘懷真教授《魏晉南北朝史》15集完整課程，適合國中生自學的歷史知識網站">
  <section class="hero">
    <div class="container-content hero-inner">
      <div class="hero-badge">臺灣大學歷史系 · 甘懷真教授 · 15 堂課程</div>
      <h1>把魏晉南北朝，讀成一個真正能理解的歷史世界。</h1>
      <p>
        從黃巾之亂到隋唐統一，這不只是朝代更替的故事，
        而是一段關於移民、族群重構、地方社會與東亞互動的 400 年歷史。
        這個網站把 15 堂課程整理成清楚、可閱讀、適合國中生循序學習的知識文本。
      </p>

      <div class="hero-actions">
        <a href="/wei-jin-history-learning/episodes" class="cta primary">開始學習</a>
        <a href="#featured-episodes" class="cta secondary">先看精選課程</a>
      </div>

      <div class="hero-meta">
        <span><span class="dot"></span> 15 集完整整理</span>
        <span><span class="dot"></span> 國中程度可讀</span>
        <span><span class="dot"></span> 兼顧史實與思辨</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-wide intro-grid">
      <div class="intro-card emphasis">
        <span class="eyebrow">這門課適合誰</span>
        <h2>想快速建立魏晉南北朝整體圖像的學生與老師</h2>
        <p>如果你覺得這段歷史人物多、政權亂、地圖難記，這套整理會先幫你抓住脈絡，再逐步理解關鍵事件與觀念。</p>
      </div>
      <div class="intro-card">
        <span class="eyebrow">你會學到什麼</span>
        <ul>
          <li>魏晉南北朝為何不是單純的「亂世」</li>
          <li>移民與族群如何改變社會結構</li>
          <li>東亞世界如何在互動中形成文化認同</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-wide instructor-card">
      <div class="instructor-mark">甘</div>
      <div class="instructor-copy">
        <span class="eyebrow">授課教師</span>
        <h2>甘懷真教授</h2>
        <div class="role">臺灣大學歷史系教授 · 中國中古史</div>
        <p>
          甘教授專精中國中古史與政治制度史。這門課的特色不是只背朝代表，
          而是訓練學生區分「事實、解釋、評價」，從移民、地方社會與東亞互動等新視角，
          重新理解魏晉南北朝這段常被簡化的歷史。
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-wide">
      <div class="section-header">
        <div>
          <span class="eyebrow">課程核心觀點</span>
          <h2 class="section-title">不是只記人物，而是建立觀察歷史的方法</h2>
        </div>
      </div>

      <div class="themes-grid">
        <div class="theme-card">
          <div class="theme-icon">🚶</div>
          <h3>大移民</h3>
          <p>移民是理解這 400 年的關鍵。族群身分不是天生固定，而是在歷史過程中逐步形成。</p>
        </div>
        <div class="theme-card">
          <div class="theme-icon">🌏</div>
          <h3>東亞世界</h3>
          <p>中國、朝鮮半島與日本列島並非孤立發展，而是在互動中塑造各自的制度與文化。</p>
        </div>
        <div class="theme-card">
          <div class="theme-icon">👥</div>
          <h3>基層社會</h3>
          <p>除了帝王將相，更要看地方社會、普通人的遷徙與生存策略，歷史才會立體。</p>
        </div>
        <div class="theme-card">
          <div class="theme-icon">🔍</div>
          <h3>史實與解釋</h3>
          <p>歷史學的第一步是辨認史實，再進一步提出解釋，最後才談價值判斷。</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="featured-episodes">
    <div class="container-wide">
      <div class="section-header">
        <div>
          <span class="eyebrow">精選課程</span>
          <h2 class="section-title">先從這 6 集開始，也能快速進入狀況</h2>
        </div>
        <a href="/wei-jin-history-learning/episodes" class="see-all">查看全部 15 集 →</a>
      </div>

      <div class="episodes-grid">
        {featuredEpisodes.map(ep => (
          <article class="ep-card">
            <div class="ep-card-header">
              <span class="ep-num">第 {ep.data.order} 集</span>
              <div class="ep-tags">
                {ep.data.tags.slice(0, 2).map(tag => <span class="ep-tag">{tag}</span>)}
              </div>
            </div>
            <h3><a href={`/wei-jin-history-learning/episodes/${ep.id}`} class="ep-title-link">{ep.data.title}</a></h3>
            <p>{ep.data.subtitle}</p>
            {ep.coreQuestions[0] && (
              <div class="core-question-preview">
                <span class="core-question-label">本課核心問題</span>
                <p>{ep.coreQuestions[0]}</p>
              </div>
            )}
            <div class="ep-actions">
              <a href={`/wei-jin-history-learning/episodes/${ep.id}`} class="ep-link">閱讀本課 →</a>
              <a href={`/wei-jin-history-learning/episodes/${ep.id}#核心問題`} class="ep-link secondary">直達核心問題 →</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 120px 0 88px;
    background:
      radial-gradient(circle at top, rgba(232, 178, 87, 0.18), transparent 34%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.015), transparent 100%);
  }

  .hero-inner {
    text-align: center;
  }

  .hero-badge,
  .eyebrow {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(232, 178, 87, 0.12);
    border: 1px solid rgba(232, 178, 87, 0.18);
    color: var(--accent-strong);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
  }

  .hero h1 {
    margin: 24px auto 18px;
    max-width: 900px;
    font-family: 'Noto Serif TC', serif;
    font-size: clamp(2.3rem, 6vw, 3.8rem);
    line-height: 1.16;
    letter-spacing: 0.01em;
  }

  .hero p {
    max-width: 720px;
    margin: 0 auto;
    color: var(--text-muted);
    font-size: clamp(1.05rem, 2.1vw, 1.15rem);
    line-height: 1.9;
  }

  .hero-actions {
    margin-top: 34px;
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  .cta {
    min-height: 50px;
    padding: 14px 24px;
    border-radius: 999px;
    text-decoration: none;
    font-size: var(--text-base);
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
  }

  .cta:hover {
    transform: translateY(-2px);
  }

  .cta.primary {
    background: var(--accent);
    color: #101521;
  }

  .cta.secondary {
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text);
  }

  .hero-meta {
    margin-top: 28px;
    display: flex;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
    color: var(--text-soft);
    font-size: var(--text-sm);
  }

  .hero-meta span {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
  }

  .section {
    padding: var(--space-section) 0;
  }

  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 32px;
  }

  .section-title {
    margin-top: 14px;
    font-family: 'Noto Serif TC', serif;
    font-size: clamp(1.7rem, 3vw, 2rem);
    line-height: 1.3;
  }

  .see-all {
    color: var(--accent-strong);
    text-decoration: none;
    font-size: var(--text-sm);
    white-space: nowrap;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 22px;
  }

  .intro-card,
  .instructor-card,
  .theme-card,
  .ep-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.035);
    box-shadow: var(--shadow-soft);
  }

  .intro-card {
    padding: 30px;
  }

  .intro-card.emphasis {
    background: linear-gradient(180deg, rgba(232, 178, 87, 0.1), rgba(255, 255, 255, 0.03));
  }

  .intro-card h2 {
    margin: 16px 0 14px;
    font-family: 'Noto Serif TC', serif;
    font-size: clamp(1.6rem, 2.6vw, 2rem);
    line-height: 1.35;
  }

  .intro-card p,
  .intro-card li {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.85;
  }

  .intro-card ul {
    margin-top: 14px;
    margin-left: 1.2rem;
    display: grid;
    gap: 10px;
  }

  .instructor-card {
    padding: 40px;
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 28px;
    align-items: start;
  }

  .instructor-mark {
    width: 110px;
    height: 110px;
    border-radius: 28px;
    background: linear-gradient(135deg, rgba(232, 178, 87, 0.9), rgba(201, 140, 44, 0.95));
    color: #151922;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Noto Serif TC', serif;
    font-size: 2.4rem;
    font-weight: 700;
  }

  .instructor-copy h2 {
    margin: 14px 0 6px;
    font-family: 'Noto Serif TC', serif;
    font-size: clamp(1.7rem, 2.5vw, 2rem);
  }

  .role {
    color: var(--accent-strong);
    font-size: var(--text-sm);
    margin-bottom: 14px;
  }

  .instructor-copy p {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.9;
    max-width: 56rem;
  }

  .themes-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 20px;
  }

  .theme-card {
    padding: 28px;
  }

  .theme-icon {
    font-size: 1.9rem;
    margin-bottom: 16px;
  }

  .theme-card h3 {
    margin-bottom: 10px;
    font-size: 1.15rem;
    color: var(--accent-strong);
  }

  .theme-card p {
    color: var(--text-muted);
    font-size: 0.98rem;
    line-height: 1.8;
  }

  .episodes-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }

  .ep-card {
    padding: 26px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }

  .ep-card:hover {
    transform: translateY(-4px);
    border-color: var(--border-strong);
    background: rgba(232, 178, 87, 0.08);
  }

  .ep-card-header {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: flex-start;
  }

  .ep-num {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--accent-strong);
  }

  .ep-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 8px;
  }

  .ep-tag {
    min-height: 30px;
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-soft);
    font-size: var(--text-xs);
  }

  .ep-card h3 {
    font-family: 'Noto Serif TC', serif;
    font-size: 1.25rem;
    line-height: 1.45;
  }

  .ep-card p {
    color: var(--text-muted);
    font-size: 0.98rem;
    line-height: 1.8;
    flex: 1;
  }

  .ep-link {
    color: var(--accent-strong);
    font-size: var(--text-sm);
    font-weight: 700;
  }

  @media (max-width: 1024px) {
    .themes-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .intro-grid,
    .episodes-grid,
    .instructor-card {
      grid-template-columns: 1fr;
    }

    .instructor-card {
      gap: 20px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 76px 0 56px;
    }

    .section {
      padding: var(--space-section-mobile) 0;
    }

    .section-header {
      align-items: flex-start;
      flex-direction: column;
    }

    .hero-meta {
      gap: 14px 18px;
    }

    .intro-card,
    .instructor-card,
    .theme-card,
    .ep-card {
      border-radius: 20px;
    }
  }

  @media (max-width: 640px) {
    .hero h1 {
      font-size: clamp(2rem, 10vw, 2.4rem);
    }

    .hero p,
    .intro-card p,
    .intro-card li,
    .instructor-copy p,
    .theme-card p,
    .ep-card p {
      font-size: 0.98rem;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .cta {
      width: 100%;
    }

    .themes-grid,
    .episodes-grid {
      grid-template-columns: 1fr;
    }

    .intro-card,
    .instructor-card,
    .theme-card,
    .ep-card {
      padding: 22px;
    }

    .instructor-mark {
      width: 84px;
      height: 84px;
      border-radius: 22px;
      font-size: 2rem;
    }

    .ep-card-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .ep-tags {
      justify-content: flex-start;
    }
  }
</style>
